# PrintStuff - Clean URLs Configuration
# Removes .php extension from all URLs

RewriteEngine On

# Redirect requests with .php extension to clean URLs (optional - for SEO)
# RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
# RewriteRule ^ /%1 [R=301,L]

# Serve .php files without the extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Redirect moved CSS files (Phase 2 restructuring)
RewriteRule ^admin-orders\.css$ css/admin-orders.css [L]

# Redirect moved JS files (Phase 3 restructuring)
RewriteRule ^admin-actions-menu\.js$ js/admin-actions-menu.js [L]
RewriteRule ^admin-analytics\.js$ js/admin-analytics.js [L]
RewriteRule ^admin-bulk-selection\.js$ js/admin-bulk-selection.js [L]
RewriteRule ^admin-dashboard\.js$ js/admin-dashboard.js [L]
RewriteRule ^admin-drag-drop\.js$ js/admin-drag-drop.js [L]
RewriteRule ^admin-menu-system\.js$ js/admin-menu-system.js [L]
RewriteRule ^admin-payment-link\.js$ js/admin-payment-link.js [L]
RewriteRule ^admin-sidebar\.js$ js/admin-sidebar.js [L]
RewriteRule ^admin-utilities\.js$ js/admin-utilities.js [L]
RewriteRule ^order-detail\.js$ js/order-detail.js [L]
RewriteRule ^simple-filters\.js$ js/simple-filters.js [L]

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(statuses|events|events-archive)\.json$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect order data directory
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/orders/.*\.json$ - [F,L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
