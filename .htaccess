# PrintStuff - Clean URLs Configuration
# Removes .php extension from all URLs

RewriteEngine On

# Redirect requests with .php extension to clean URLs (optional - for SEO)
# RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
# RewriteRule ^ /%1 [R=301,L]

# Serve .php files without the extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(statuses|events|events-archive)\.json$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect order data directory
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/orders/.*\.json$ - [F,L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
